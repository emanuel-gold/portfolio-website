{% import "components/icons.njk" as icons %}
{% from "macros/projectCard.njk" import projectCard %}
{% set projects = collections.portfolio | sortByOrderThenDate %}
{% set featuredProjects = collections.featuredPortfolio | default([]) | sortByOrderThenDate %}
{% set featuredDefaults = featuredProjects | slice(0, 3) %}
{% set featuredOverflow = featuredProjects | slice(3) %}
{% set allTags = projects | allTags %}

<section id="projects" class="scroll-mt-24 py-14 sm:py-16">
  <div class="mx-auto w-full max-w-6xl px-5 sm:px-8">
    <div class="mb-10">
      <div class="mb-2 inline-block rounded-full border px-3 py-1 text-xs uppercase opacity-70">Recent work</div>
        <h2>My Recent Projects</h2>
      </div>
<div id="projects-animated">

    {% include "partials/tag-filter.njk" %}

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3" data-project-grid data-aos="fade-up" data-aos-anchor="#projects-animated" data-aos-delay="300">
      {% if featuredDefaults | length > 0 %}
        {% for project in featuredDefaults %}
          {{ projectCard(project, "grid", true, "true") | safe }}
        {% endfor %}
        {% for project in featuredOverflow %}
          {{ projectCard(project, "grid", false, "false") | safe }}
        {% endfor %}
        {% for project in projects %}
          {% if project not in featuredProjects %}
            {{ projectCard(project, "grid", false, "false") | safe }}
          {% endif %}
        {% endfor %}
      {% else %}
        {% for project in projects %}
          {{ projectCard(project, "grid", loop.index <= 3, (loop.index <= 3) | string) | safe }}
        {% endfor %}
      {% endif %}
    </div>
    <p class="hidden mt-4 py-4 text-center opacity-70" data-empty-state>No projects match that search.</p>
    <div class="mt-8 inline-flex" data-aos="fade-up" data-aos-anchor="#projects-animated" data-aos-delay="500">
      <a
      href="/portfolio/"
      class="cta-solid"
      data-scroll
      >
      See all my work
        <svg class="overflow-visible ml-1" width="4" viewBox="0 0 3 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M0 0L3 3L0 6"></path>
        </svg>
      </a>
    </div>
  </div>
  </div>
</section>