{% import "components/icons.njk" as icons %}
<section id="contact" class="scroll-mt-24 py-14 sm:py-16">
  <div class="mx-auto w-full max-w-6xl px-5 sm:px-8">
    <div class="mb-10">
      {% if site.contact.eyebrow %}
      <div class="mb-2 inline-block rounded-full border px-3 py-1 text-xs uppercase opacity-70">{{ site.contact.eyebrow }}</div>
      {% endif %}
      <h2>{{ site.contact.title }}</h2>
    </div>
    <div class="rounded-3xl border p-8 md:p-10 text-center shadow-md bg-white dark:bg-gray-950 dark:border-slate-800">
      <p class="mx-auto mb-6 max-w-3xl text-lg opacity-90">{{ site.contact.message }}</p>
      <div class="flex flex-col sm:flex-row justify-center gap-3">
        <a
          href="mailto:{{ site.contact.email }}"
          class="cta-solid"
        >
          {{ icons.mail('w-5 h-5') }} Email me
        </a>
        <a
          href="{{ site.contact.github.href }}"
          class="cta-transparent"
          target="_blank"
        >
          {{ icons.github('w-5 h-5') }} {{ site.contact.github.label }}
        </a>
      </div>
      <div class="mt-6 flex flex-wrap justify-center gap-x-4 gap-y-1 text-sm opacity-60">
        <span>{{ site.contact.email }}</span>
        <span class="hidden sm:inline" aria-hidden="true">&middot;</span>
        <span>{{ site.hero.location }}</span>
        <span class="hidden sm:inline" aria-hidden="true">&middot;</span>
        <span>{{ site.hero.availability }}</span>
      </div>
    </div>
  </div>
</section>