{# Hero with interactive mockup screens #}
{% import "components/icons.njk" as icons %}
<section id="top" class="bg-slate-100 bg-linear-to-b from-light-gradient-start to-white dark:from-gray-950 dark:to-dark-gradient-end overflow-hidden">
  <div class="mx-auto w-full max-w-6xl px-5 sm:px-8">
    <div class="lg:flex items-center gap-10 py-20">
      <div class="content-wrapper flex flex-col lg:basis-5/12 shrink-0 text-center items-center max-w-screen-sm mx-auto lg:mx-0 lg:items-start lg:text-left">
        <p class="mb-3 inline-flex items-center gap-2 text-xs uppercase opacity-70">
          <span class="h-2 w-2 rounded-full bg-emerald-500"></span> {{ site.hero.availability }}
        </p>
        <div class="scrolling-header-section hero heading-h-readable w-full flex justify-center flex-col h-full relative">
            <h1 class="hero_heading animated-h1 font-black">
              <span class="brand-gradient-right bg-clip-text text-transparent">Emanuel Gold:</span><span class="block"></span>
              <span class="hero_header-scrolling-wrapper inline-block m-auto overflow-hidden align-bottom">
                <ul class="hero_header-scrolling-list m-0 p-0 inline-block list-none">
                  <li class="header-scrolling-list-item text-center lg:text-left items-start m-0 p-0 list-none after:content-['.'] after:text-brand-gold"> web developer</li>
                  <li class="header-scrolling-list-item text-center lg:text-left items-start m-0 p-0 list-none after:content-['.'] after:text-brand-gold"> project manager</li>
                  <li class="header-scrolling-list-item text-center lg:text-left items-start m-0 p-0 list-none after:content-['.'] after:text-brand-gold"> martech expert</li>
                  <li class="header-scrolling-list-item text-center lg:text-left items-start m-0 p-0 list-none after:content-['.'] after:text-brand-gold"> problem solver</li>
                  <li class="header-scrolling-list-item text-center lg:text-left items-start m-0 p-0 list-none after:content-['.'] after:text-brand-gold"> web developer</li>
                </ul>
              </span>
            </h1>
          <script type="application/json" id="heading-h-readable_scroll-animation-settings" nonce="">
              {
                "animationSpeed": 1100,
                "animationPause": 1700,
                "animationScrollHeight": 240,
                "animationEasingFunction": "cubic-bezier(0.66, 0.00, 0.24, 1.00)"
              }
            </script>
        </div>
        <p class="mb-8 max-w-[52ch] text-lg opacity-90 ">{{ site.hero.summary }}</p>
        <div class="flex flex-col sm:flex-row justify-center w-full lg:justify-start flex-wrap gap-6">
          <a
            href="{{ site.hero.primaryCta.href }}"
            class="cta-solid"
          >
            {{ icons.mail('w-5 h-5') }} {{ site.hero.primaryCta.label }}
          </a>
          <a
            href="{{ site.hero.secondaryCta.href }}"
            class="cta-transparent"
            data-scroll
          >
            {{ icons.file_text('w-5 h-5') }} {{ site.hero.secondaryCta.label }}
          </a>
        </div>
        <div class="mt-6 flex items-center gap-4 text-sm opacity-80">
          <span class="inline-flex items-center gap-1">{{ icons.map_pin('w-4 h-4') }} {{ site.hero.location }}</span>
        </div>
      </div>
      <div class="image-wrapper hidden sm:grid mt-12 lg:mt-0 lg:basis-7/12 grid-cols-mockup grid-rows-mockup place-content-center">
        <a href="/portfolio/trackur-app/" class="z-40 mockup-screen mockup-screen-front" aria-label="Learn more about Trackur, an app built by Emanuel Gold.">
          <img
            src="/img/Trackur home page.webp"
            class="rounded-xs bg-gray-50 shadow-xl ring-1 ring-gray-900/10 dark:hidden"
            alt="Trackur.app home page screenshot.">
          <img
            src="/img/Trackur home page.webp"
            class="hidden rounded-xs bg-white/5 shadow-2xl ring-1 ring-white/10 dark:block"
            alt="Trackur.app home page screenshot.">
        </a>
        <a href="/portfolio/rampquest/" class="z-30 mockup-screen mockup-screen-mid" aria-label="Learn more about the RAMPQuest.org website development project by Emanuel Gold.">
          <img
            src="/img/RAMPQuest home page.webp"
            class="rounded-xs bg-gray-50 shadow-xl ring-1 ring-gray-900/10 dark:hidden"
            alt="RAMPQuest.org home page screenshot.">
          <img
            src="/img/RAMPQuest home page.webp"
            class="hidden rounded-xs bg-white/5 shadow-2xl ring-1 ring-white/10 dark:block"
            alt="RAMPQuest.org home page screenshot.">
        </a>
        <a href="/portfolio/govramp-website-refresh/" class="z-20 mockup-screen mockup-screen-back" aria-label="Learn more about the GovRAMP.org website development project by Emanuel Gold.">
          <img
            src="/img/GovRAMP home page.webp"
            class="rounded-xs bg-gray-50 shadow-xl ring-1 ring-gray-900/10 dark:hidden"
            alt="GovRAMP.org home page screenshot.">
          <img
            src="/img/GovRAMP home page.webp"
            class="hidden rounded-xs bg-white/5 shadow-2xl ring-1 ring-white/10 dark:block"
            alt="GovRAMP.org home page screenshot.">
        </a>
      </div>
    </div>
  </div>
</section>
