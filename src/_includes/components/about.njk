<section id="about" class="scroll-mt-24 py-14 sm:py-16">
  <div class="mx-auto w-full max-w-6xl px-5 sm:px-8">
    <div class="mb-10">
      {% if site.about.eyebrow %}
      <div class="mb-2 inline-block rounded-full border px-3 py-1 text-xs uppercase opacity-70">{{ site.about.eyebrow }}</div>
      {% endif %}
      <h2>{{ site.about.title }}</h2>
    </div>
    <div class="grid grid-cols-1 items-start gap-8 md:grid-cols-3">
      <div class="md:col-span-2" data-aos="fade-right" data-aos-delay="300">
        {% for paragraph in site.about.paragraphs %}
          <p class="mb-4 leading-relaxed opacity-90">{{ paragraph }}</p>
        {% endfor %}
        <ul class="list-none m-0 p-0 opacity-90">
          {% for point in site.about.bulletPoints %}
            <li class="flex items-start gap-3 mb-3 m-0 p-0 list-none">
              <span class="w-1.5 h-1.5 rounded-full bg-brand-gold shrink-0 mt-2.5"></span>
              <span>{{ point }}</span>
            </li>
          {% endfor %}
        </ul>
      </div>
      <div class="rounded-2xl border-2 border-brand-gold p-5.5 bg-white dark:bg-gray-950 dark:border-brand-gold" data-aos="fade-left" data-aos-delay="500">
        {# <h4 class="mb-3">Quick facts</h4> #}
        <dl class="grid grid-cols-1 gap-4 text-md">
          {% for fact in site.about.facts %}
            <div class="flex items-center justify-between">
              <dt class="opacity-70">{{ fact.term }}</dt>
              <dd>{{ fact.description }}</dd>
            </div>
          {% endfor %}
        </dl>
      </div>
    </div>
  </div>
</section>
