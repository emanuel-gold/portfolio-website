{%- set pageTitle = title or site.meta.title -%}
{%- set pageDescription = description or blurb or site.meta.description -%}
{%- set baseUrl = site.meta.url | replace(r/\/$/g, '') -%}
{%- set pageUrl = baseUrl ~ page.url -%}
{%- set pageImage = header_image or thumbnail or '/img/og-default.jpg' -%}
{%- set fullImageUrl = baseUrl ~ pageImage -%}
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ pageTitle }}</title>
    <meta name="description" content="{{ pageDescription }}" />
    <meta name="author" content="{{ site.footer.owner }}" />
    <link rel="canonical" href="{{ pageUrl }}" />

    <!-- Open Graph -->
    <meta property="og:title" content="{{ pageTitle }}" />
    <meta property="og:description" content="{{ pageDescription }}" />
    <meta property="og:url" content="{{ pageUrl }}" />
    <meta property="og:type" content="{% if layout == 'layouts/post.njk' %}article{% else %}website{% endif %}" />
    <meta property="og:image" content="{{ fullImageUrl }}" />
    <meta property="og:site_name" content="{{ site.meta.siteName }}" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ pageTitle }}" />
    <meta name="twitter:description" content="{{ pageDescription }}" />
    <meta name="twitter:image" content="{{ fullImageUrl }}" />
    <link rel="preload" href="/assets/fonts/bebas-neue.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="stylesheet" href="/assets/main.css" />
    <!--GOOGLE FONTS (non-render-blocking)-->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet"></noscript>
    <!--END GOOGLE FONTS-->
    <!--AOS loaded non-blocking at end of body-->
    <link rel="icon" href="/img/Personal-Logo-Favicon-Black-background-round-corner-300x300.png" sizes="192x192" type="image/png">
    <script>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = stored || (prefersDark ? "dark" : "light");
        if (theme === "dark") {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
    {% if layout == "layouts/post.njk" %}<script src="/assets/post-scroll-progress-bar.js" defer></script>{% endif %}
    <style>
      .hero{--hero-height:calc(100dvh - var(--global-nav-header-height))}.hero:not(.wf-above-the-fold *){height:var(--hero-height);transition:height .3s ease-out}.heading-h-readable.hero{--hero-image-loaded-speed:400ms;--hero-image-loaded-easing-function:ease-out}.heading-h-readable .hero_heading{--hero-heading-custom-line-height:4rem;line-height:var(--hero-heading-custom-line-height)}.heading-h-readable .hero_header-scrolling-wrapper{height:var(--hero-heading-custom-line-height)}.heading-h-readable .header-scrolling-list-item{line-height:var(--hero-heading-custom-line-height);height:var(--hero-heading-scroll-height);margin-block:0}@media (prefers-reduced-motion:reduce){.heading-h-readable .hero,.heading-h-readable .hero::before,.heading-h-readable .hero_description,.heading-h-readable .hero_heading,.heading-h-readable .hero_tagline{transition:none}}
    </style>
  </head>
  <body class="min-h-screen bg-slate-100 text-gray-900 antialiased dark:bg-slate-950 dark:text-gray-100" data-aos-easing="ease-out" data-aos-delay="0">
    {{ content | safe }}
    <script type="application/ld+json">
      {{ {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": site.footer.owner,
        "url": site.meta.url,
        "sameAs": site.meta.sameAs,
        "jobTitle": site.meta.jobTitle
      } | dump | safe }}
    </script>
    <script src="/assets/main.js" type="module"></script>
    <script src="/assets/scrollingText.js"></script>
    <link rel="stylesheet" href="/assets/aos.css" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="/assets/aos.css"></noscript>
    <script src="/assets/aos.js" async onload="AOS.init({ once: true, duration: 600 });"></script>
    {% if layout == "layouts/post.njk" %}<script src="/assets/imageHotspots.js" type="module"></script>{% endif %}
  </body>
</html>
