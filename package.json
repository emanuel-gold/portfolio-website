{
  "name": "emanuel-gold-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "npm run build:css && eleventy",
    "build:css": "npx @tailwindcss/cli -i ./tailwind.css -o ./_site/css/styles.css -m",
    "watch:css": "npx @tailwindcss/cli -i ./tailwind.css -o ./_site/css/styles.css -w",
    "serve": "eleventy --serve --quiet",
    "dev": "npm-run-all --parallel watch:css serve",
    "site-editor": "node tools/site-editor/server.js"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.21",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.17",
    "aos": "^2.3.4",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-image-figures": "^2.1.1"
  }
}
